# Discord OAuth2 Configuration
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=https://your-domain.com
DISCORD_GUILD_ID=your_discord_server_id_here
VERIFIED_ROLE_ID=your_verified_role_id_here

# Callback URL - full URL where to redirect users after successful authentication
CALLBACK_URL=https://your-frontend-domain.com/verification/callback

# Error URL - URL where to redirect users on authentication errors (include ?msg parameter)
# Example: https://your-frontend-domain.com/verification/error?msg
ERROR_URL=https://your-frontend-domain.com/verification/error?msg